rules_version = '2';

// NOTE: This is a placeholder allowing any authenticated user to read/write.
// Step 26 replaces this with the production rule set. Do NOT deploy these
// rules to a public production environment as-is.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
