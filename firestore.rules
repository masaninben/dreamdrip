rules_version = '2';

// Dreamdrip — Firestore Security Rules
//
// Design principles:
//  - Users can only read & write their own user document and dreams.
//  - publicDreams are world-readable (anonymous), but each doc must be tied
//    to a dream owned by the writer.
//  - tags is a global counter shared by all authenticated users (write
//    constrained to small, increment-shaped payloads).
//  - announcements are admin-managed; clients can read published items and
//    bootstrap the single "welcome" doc on first run.
//  - userReadAnnouncements is owned by each user.
//
// Note on string sizes:
//  Firestore rules' `string.size()` returns the number of UTF-8 bytes,
//  not Unicode code points. The product spec is in characters (e.g.
//  "200 文字"), so byte limits are sized at ~4× the character cap to
//  accommodate worst-case multi-byte UTF-8 (Japanese ~3 bytes, emoji
//  surrogate pairs up to 4). The client computes textLength via
//  `Array.from(text).length` (code points) and is constrained
//  separately so users can't fabricate a length that disagrees with the
//  rendered character count.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incomingHasOnly(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function optionalString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function isStringArray(value, maxItems, maxLength) {
      return value is list
        && value.size() <= maxItems
        && (value.size() < 1 || (value[0] is string && value[0].size() <= maxLength))
        && (value.size() < 2 || (value[1] is string && value[1].size() <= maxLength))
        && (value.size() < 3 || (value[2] is string && value[2].size() <= maxLength))
        && (value.size() < 4 || (value[3] is string && value[3].size() <= maxLength))
        && (value.size() < 5 || (value[4] is string && value[4].size() <= maxLength))
        && (value.size() < 6 || (value[5] is string && value[5].size() <= maxLength))
        && (value.size() < 7 || (value[6] is string && value[6].size() <= maxLength))
        && (value.size() < 8 || (value[7] is string && value[7].size() <= maxLength))
        && (value.size() < 9 || (value[8] is string && value[8].size() <= maxLength))
        && (value.size() < 10 || (value[9] is string && value[9].size() <= maxLength));
    }

    function isLocationPrecision(value) {
      return value in ['city', 'region'];
    }

    function isLocationMode(value) {
      return value in ['gps', 'manual_city', 'region_only'];
    }

    function isCardType(value) {
      return value in ['text', 'tags', 'emotion', 'fragment'];
    }

    function isVisibility(value) {
      return value in ['private', 'anonymous_public'];
    }

    // ---------- users ----------

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && incomingHasOnly([
          'uid',
          'displayName',
          'email',
          'photoURL',
          'createdAt',
          'updatedAt',
          'lastLoginAt',
          'onboardingCompleted',
          'locationMode',
          'locationPrecision',
          'country',
          'region',
          'city',
          'defaultVisibility',
          'deletedAt'
        ])
        && request.resource.data.onboardingCompleted == false
        && request.resource.data.defaultVisibility == 'anonymous_public'
        && request.resource.data.deletedAt == null;
      allow update: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastLoginAt',
          'onboardingCompleted',
          'locationMode',
          'locationPrecision',
          'country',
          'region',
          'city',
          'updatedAt',
          'deletedAt'
        ])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['locationMode'])
          || isLocationMode(request.resource.data.locationMode))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['locationPrecision'])
          || isLocationPrecision(request.resource.data.locationPrecision))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['country'])
          || optionalString(request.resource.data.country, 2))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['region'])
          || optionalString(request.resource.data.region, 120))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['city'])
          || optionalString(request.resource.data.city, 120));
      allow delete: if false;
    }

    // ---------- dreams ----------

    match /dreams/{dreamId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.id == dreamId
        && request.resource.data.visibility in ['private', 'anonymous_public']
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000
        && request.resource.data.textLength is int
        && request.resource.data.textLength >= 0
        && request.resource.data.textLength <= 200
        && isStringArray(request.resource.data.emotions, 9, 48)
        && isStringArray(request.resource.data.tags, 10, 80);
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'text',
          'textLength',
          'emotions',
          'tags',
          'visibility',
          'updatedAt',
          'deletedAt'
        ])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['visibility'])
          || isVisibility(request.resource.data.visibility))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['text'])
          || (request.resource.data.text is string && request.resource.data.text.size() <= 1000))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['textLength'])
          || (request.resource.data.textLength is int
              && request.resource.data.textLength >= 0
              && request.resource.data.textLength <= 200))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['emotions'])
          || isStringArray(request.resource.data.emotions, 9, 48))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['tags'])
          || isStringArray(request.resource.data.tags, 10, 80));
      allow delete: if false; // soft delete via update only
    }

    // ---------- publicDreams ----------
    //
    // Reads are open to any signed-in user (the feed is anonymous; userIdHash
    // is used instead of userId so the original owner cannot be identified).
    //
    // Create: ownership check via get(/dreams/$id) is not viable here because
    // the corresponding dreams doc is written in the same batch and rules
    // evaluate exists()/get() against pre-batch state. We instead enforce a
    // tight document shape and rely on the unguessable random dreamId. The
    // companion dreams write in the same batch is itself owner-gated, so a
    // user cannot add a public reflection of a dream they don't actually
    // create.
    //
    // Update: by then dreams/$id exists, so we can verify ownership.

    function isOwnerOfDream(dreamId) {
      return exists(/databases/$(database)/documents/dreams/$(dreamId))
        && get(/databases/$(database)/documents/dreams/$(dreamId)).data.userId == request.auth.uid;
    }

    function willOwnDream(dreamId) {
      return existsAfter(/databases/$(database)/documents/dreams/$(dreamId))
        && getAfter(/databases/$(database)/documents/dreams/$(dreamId)).data.userId == request.auth.uid;
    }

    function isPublicDreamShape(dreamId) {
      return incomingHasOnly([
          'dreamId',
          'userIdHash',
          'textPreview',
          'emotions',
          'tags',
          'dreamDate',
          'recordedAt',
          'country',
          'region',
          'city',
          'locationPrecision',
          'cardType',
          'deletedAt'
        ])
        && request.resource.data.dreamId == dreamId
        && request.resource.data.userIdHash is string
        && request.resource.data.userIdHash.size() > 0
        && request.resource.data.userIdHash.size() <= 80
        && request.resource.data.textPreview is string
        && request.resource.data.textPreview.size() <= 240
        && isStringArray(request.resource.data.emotions, 9, 48)
        && isStringArray(request.resource.data.tags, 10, 80)
        && request.resource.data.dreamDate is string
        && request.resource.data.dreamDate.size() == 10
        && optionalString(request.resource.data.country, 2)
        && optionalString(request.resource.data.region, 120)
        && optionalString(request.resource.data.city, 120)
        && isLocationPrecision(request.resource.data.locationPrecision)
        && isCardType(request.resource.data.cardType)
        && request.resource.data.deletedAt == null;
    }

    match /publicDreams/{dreamId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && request.query.limit != null
        && request.query.limit <= 100;
      allow create: if isSignedIn()
        && willOwnDream(dreamId)
        && getAfter(/databases/$(database)/documents/dreams/$(dreamId)).data.visibility == 'anonymous_public'
        && isPublicDreamShape(dreamId);
      allow update: if isSignedIn()
        && isOwnerOfDream(dreamId)
        && request.resource.data.dreamId == dreamId
        && request.resource.data.userIdHash == resource.data.userIdHash
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'textPreview',
          'emotions',
          'tags',
          'cardType',
          'deletedAt'
        ])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['textPreview'])
          || (request.resource.data.textPreview is string && request.resource.data.textPreview.size() <= 240))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['emotions'])
          || isStringArray(request.resource.data.emotions, 9, 48))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['tags'])
          || isStringArray(request.resource.data.tags, 10, 80))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['cardType'])
          || isCardType(request.resource.data.cardType));
      allow delete: if false;
    }

    // ---------- tags ----------
    //
    // Shared global counter. Any signed-in user may create or update a tag,
    // but the payload shape is constrained.

    match /tags/{tagName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['name', 'count', 'lastUsedAt', 'createdAt'])
        && request.resource.data.name == tagName
        && request.resource.data.count == 1;
      allow update: if isSignedIn()
        && request.resource.data.keys().hasOnly(['name', 'count', 'lastUsedAt', 'createdAt'])
        && request.resource.data.name == tagName
        && (!request.resource.data.keys().hasAny(['createdAt'])
          || request.resource.data.createdAt == resource.data.createdAt)
        && request.resource.data.count == resource.data.count + 1;
      allow delete: if false;
    }

    // ---------- announcements ----------
    //
    // Reads: any signed-in user may read published announcements.
    // Writes: only the bootstrap "welcome" doc may be created by clients,
    // and only if it does not already exist. Updates/deletes from clients
    // are forbidden — operate via Firebase Console / Admin SDK instead.

    match /announcements/{announcementId} {
      allow read: if isSignedIn() && resource.data.published == true;
      allow create, update, delete: if false;
    }

    // ---------- userReadAnnouncements ----------
    //
    // Each document tracks one user's read state of one announcement.
    // The doc id must follow `${uid}_${announcementId}`.

    match /userReadAnnouncements/{readId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && readId == request.auth.uid + '_' + request.resource.data.announcementId;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ---------- default deny ----------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
